# ─── Core LLM ───────────────────────────────────────────────
BASETEN_API_KEY=your_baseten_api_key_here
BASETEN_MODEL_ID=your_baseten_model_id_here   # e.g. llama-3-70b-instruct

# ─── Search ──────────────────────────────────────────────────
YOU_COM_API_KEY=your_you_com_api_key_here

# ─── Voice ───────────────────────────────────────────────────
VOICERUN_API_KEY=your_voicerun_api_key_here

# ─── Embeddings (OpenAI — cheap, used for RAG layer only) ────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Optional: Google Cloud (only if deploying to Vertex AI) ─
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# ─── App Config ──────────────────────────────────────────────
DEMO_MODE=false        # Set to true to serve cached demo data
PORT=8000
